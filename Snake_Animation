main.yml ->
name: Generate Snake Animation

on:
  schedule:
    - cron: "0 0 * * *"
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # Checkout the repository
      - uses: actions/checkout@v3

      # Generate the snake animation and export it as a .svg file
      - uses: Platane/snk@v3
        with:
          github_user_name: umitarat-dev
          outputs: 
            dist/github-contribution-grid-snake.svg
            dist/github-contribution-grid-snake-dark.svg?palette=github-dark
            
      # Commit and push the generated snake.svg to the output branch
      - name: Commit and push changes
        uses: stefanzweifel/git-auto-commit-action@v4
        with:
          commit_message: "Updated Snake Animation"
          branch: output
          create_branch: true # Eğer output branch'i yoksa oluşturur
          file_pattern: dist/snake.svg


